@model JobTracker.ViewLogic.ViewModels.JobApplicationViewModel

@{
    ViewData["Title"] = "Delete Application";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">← Back</a>
            <h2 class="mb-0">Delete Application</h2>
        </div>

        <div class="card border-danger shadow-sm">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="display-4">🗑️</span>
                </div>
                <h4>Are you sure?</h4>
                <p class="text-muted">
                    You are about to delete your application for
                    <strong>@Model.JobTitle</strong> at <strong>@Model.CompanyName</strong>.
                </p>
                <p class="text-muted small">
                    Applied: @Model.DateApplied.ToString("dd MMM yyyy") &nbsp;|&nbsp; Status: @Model.Status
                </p>
                <p class="text-danger">This action cannot be undone.</p>

                <form asp-action="Delete" method="post" class="d-inline">
                    @* ValidateAntiForgeryToken requires this hidden field to match a server-side token *@
                    <button type="submit" class="btn btn-danger me-2">Yes, Delete It</button>
                </form>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
